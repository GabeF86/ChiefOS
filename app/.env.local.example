# ChiefOS environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored; this example file is checked in.

# --- Supabase ---
# Get these from https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Phase 2 — vault chat) ---
# Get a key at https://console.anthropic.com.
# Enable "zero data retention" at the org level per PRD §3.
ANTHROPIC_API_KEY=

# --- OpenAI (embeddings + Whisper) ---
# Get a key at https://platform.openai.com/api-keys
# Whisper costs ~$0.006/min; embeddings ~$0.02/1M tokens.
OPENAI_API_KEY=

# --- Vault webhook (Phase 2) ---
# Set up after the vault GitHub repo exists.
# GITHUB_VAULT_REPO format: "owner/repo" (e.g. "GabeF86/chiefos-vault").
# GITHUB_TOKEN needs repo:contents:read on the vault repo only.
# GITHUB_WEBHOOK_SECRET is the shared secret configured in the GitHub webhook UI.
# CHIEFOS_VAULT_USER_ID is the auth.users.id (UUID) whose vault this is.
GITHUB_VAULT_REPO=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
CHIEFOS_VAULT_USER_ID=

# --- Obsidian (optional) ---
# Set to your Obsidian vault name so citation chips can open notes via
# `obsidian://` on macOS. Safe to leave blank — chips still display.
NEXT_PUBLIC_OBSIDIAN_VAULT_NAME=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
