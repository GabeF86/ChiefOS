# Copy to .env for local dev. Railway holds these as secrets in production.

SPINFUSION_ORG=
SPINFUSION_USERNAME=
SPINFUSION_PASSWORD=
SPINFUSION_LOGIN_URL=https://www.spinfusion.com/SpinSchedules/login

# The saved report's name in Spinfusion → Reports list.
SPINFUSION_REPORT_NAME=Paoli — MDs + CRNAs (rolling 4 weeks)

# Dev shortcut: point at a manually exported CSV to skip the report-download
# flow entirely. Leave blank in production.
SPINFUSION_LOCAL_CSV=

SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
CHIEFOS_VAULT_USER_ID=

DAYS_AHEAD=28
SITE_NAME=Paoli

# Optional alerting (Resend) — leave blank to skip email on failure.
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
